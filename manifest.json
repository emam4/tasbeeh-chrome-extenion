{
    "name": "Tasbeeh",
    "version": "2.0",
    "manifest_version": 3,
    "description": "Tasbeeh",
    "icons": {
        "16":  "assets/icons/icon16.png",
        "32":  "assets/icons/icon32.png",
        "48":  "assets/icons/icon48.png",
        "128": "assets/icons/icon128.png"
    },
    "action": {
        "default_icon": {
            "16":  "assets/icons/icon16.png",
            "32":  "assets/icons/icon32.png",
            "48":  "assets/icons/icon48.png",
            "128": "assets/icons/icon128.png"
        },
        "default_popup": "src/popup/popup.html"
    },
    "content_scripts": [
        {
            "js": [
                "src/data/constants.js",
                "src/data/data.js",
                "src/content/content.js"
            ],
            "matches": [
                "https://*/*"
            ]
        }
    ],
    "permissions": ["storage"]

}